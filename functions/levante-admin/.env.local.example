# Copy this file to .env.local next to functions/levante-admin/package.json
# (not inside src/). The Firebase emulator loads .env.local from the Functions root.
# See: https://resend.com/docs/send-with-smtp

CREATE_USERS_EXPORT_SMTP_HOST=smtp.resend.com
CREATE_USERS_EXPORT_SMTP_PORT=465
CREATE_USERS_EXPORT_SMTP_USER=resend
CREATE_USERS_EXPORT_MAIL_FROM=Levante <noreply@levante-network.org>
